<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:FrontendMaui.ViewModels"
             x:Class="FrontendMaui.Views.CamionsPage"
             Title="Camions">

    <!-- BindingContext is provided by DI in the code-behind (constructor injection) -->

    <RefreshView IsRefreshing="{Binding IsBusy}" Command="{Binding RefreshCommand}">
        <CollectionView ItemsSource="{Binding Camions}" SelectionMode="Single" SelectedItem="{Binding SelectedCamion, Mode=TwoWay}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                <Border StrokeShape="RoundRectangle 8" Padding="12" Margin="8" BackgroundColor="White">
                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                        <Label Text="{Binding Immatriculation}" FontAttributes="Bold" Grid.Row="0" Grid.Column="0" />
                        <Label Text="{Binding Modele}" Grid.Row="1" Grid.Column="0" FontSize="12" Opacity="0.8" />
                        <Label Text="{Binding Kilometrage}" Grid.Row="0" Grid.Column="1" VerticalOptions="Center" />
                    </Grid>
                </Border>
            </DataTemplate>
        </CollectionView.ItemTemplate>
        </CollectionView>
    </RefreshView>

</ContentPage>
