<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="FrontendMaui.Views.WelcomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False"
    BackgroundColor="#0F0F12">

    <Grid RowDefinitions="Auto,*">

        <!-- ================= NAVBAR (HEADER FIXE) ================= -->
        <Border Grid.Row="0" HeightRequest="70" BackgroundColor="#16161C" Stroke="#23232C" StrokeThickness="1" Padding="20,0">
            <Grid ColumnDefinitions="*,Auto">
                <!-- Logo à gauche -->
                <HorizontalStackLayout Grid.Column="0" Spacing="10" VerticalOptions="Center">
                    <Label
                        Text="TCA"
                        FontSize="26"
                        FontAttributes="Bold"
                        TextColor="#FF7D29"
                        VerticalOptions="Center" />
                    <BoxView WidthRequest="1.5" HeightRequest="20" Color="#3D3D4B" VerticalOptions="Center" />
                    <Label
                        Text="Guinée Mining SA"
                        FontSize="13"
                        TextColor="#9E9EAF"
                        FontAttributes="Italic"
                        VerticalOptions="Center" />
                </HorizontalStackLayout>

                <!-- Navigation à droite -->
                <HorizontalStackLayout Grid.Column="1" Spacing="24" VerticalOptions="Center">
                    <!-- Bouton Connexion (Style texte) -->
                    <Label
                        Text="Connexion"
                        TextColor="White"
                        FontSize="15"
                        FontAttributes="Bold"
                        VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnSeConnecterClicked" />
                        </Label.GestureRecognizers>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Property="TextColor" Value="White" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Property="TextColor" Value="#FF7D29" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>
                    </Label>

                    <!-- Bouton S'inscrire (Style rempli orange) -->
                    <Button
                        Text="S'inscrire"
                        BackgroundColor="#FF7D29"
                        TextColor="White"
                        FontSize="14"
                        FontAttributes="Bold"
                        HeightRequest="38"
                        Padding="16,0"
                        CornerRadius="6"
                        Clicked="OnSInscrireClicked">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroupList>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="#FF7D29" />
                                            <Setter Property="Scale" Value="1.0" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Property="BackgroundColor" Value="#FF944D" />
                                            <Setter Property="Scale" Value="1.04" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Property="Scale" Value="0.96" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateGroupList>
                        </VisualStateManager.VisualStateGroups>
                    </Button>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- ================= CONTENU DE LA PAGE ================= -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">

                <!-- 1. HERO BANNER -->
                <Grid HeightRequest="560">
                    <!-- Image de fond (Bauxite mining dump truck) -->
                    <Image
                        Source="welcome_bg.png"
                        Aspect="AspectFill"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />

                    <!-- Overlay avec dégradé noir de droite à gauche pour masquer/assombrir la photo et lire le texte -->
                    <BoxView
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#EC000000" Offset="0.0" />
                                <GradientStop Color="#CC000000" Offset="0.4" />
                                <GradientStop Color="#55000000" Offset="1.0" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>

                    <!-- Texte et boutons alignés à gauche -->
                    <Grid RowDefinitions="*,Auto" Padding="40,60,40,60">
                        <VerticalStackLayout Grid.Row="0" Spacing="20" VerticalOptions="Center" MaximumWidthRequest="650" HorizontalOptions="Start">
                            <!-- Badge de localisation -->
                            <Border Stroke="Transparent" BackgroundColor="#E6FF7D29" StrokeShape="RoundRectangle 4" HorizontalOptions="Start" Padding="10,4">
                                <Label Text="BOKÉ, GUINÉE" TextColor="White" FontSize="11" FontAttributes="Bold" CharacterSpacing="1.5" />
                            </Border>

                            <!-- Titre -->
                            <Label
                                Text="Pilotez votre logistique"
                                FontSize="42"
                                FontAttributes="Bold"
                                TextColor="White"
                                LineHeight="1.1" />
                            <Label
                                FontSize="42"
                                FontAttributes="Bold"
                                LineHeight="1.1"
                                Margin="0,-10,0,0">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="minière " TextColor="White" />
                                        <Span Text="en temps réel" TextColor="#FF7D29" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                            <!-- Sous-titre -->
                            <Label
                                Text="Suivi de la flotte de camions, enregistrement des trajets vers les zones minières, calcul des carburants consommés et paiement des primes chauffeurs."
                                FontSize="17"
                                TextColor="#C4C4D4"
                                LineHeight="1.3" />
                        </VerticalStackLayout>

                        <!-- Actions héro -->
                        <HorizontalStackLayout Grid.Row="1" Spacing="16" HorizontalOptions="Start">
                            <Button
                                Text="Accéder à la flotte"
                                BackgroundColor="#FF7D29"
                                TextColor="White"
                                FontAttributes="Bold"
                                HeightRequest="48"
                                Padding="24,0"
                                CornerRadius="8"
                                Clicked="OnSeConnecterClicked">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="#FF7D29" />
                                                    <Setter Property="Scale" Value="1.0" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="PointerOver">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="#FF944D" />
                                                    <Setter Property="Scale" Value="1.04" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                            </Button>

                            <Button
                                Text="Espace superviseur"
                                BackgroundColor="#2D2D37"
                                BorderColor="#3E3E4F"
                                BorderWidth="1.5"
                                TextColor="White"
                                HeightRequest="48"
                                Padding="24,0"
                                CornerRadius="8"
                                Clicked="OnSeConnecterClicked">
                                <VisualStateManager.VisualStateGroups>
                                    <VisualStateGroupList>
                                        <VisualStateGroup x:Name="CommonStates">
                                            <VisualState x:Name="Normal">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="#2D2D37" />
                                                    <Setter Property="Scale" Value="1.0" />
                                                </VisualState.Setters>
                                            </VisualState>
                                            <VisualState x:Name="PointerOver">
                                                <VisualState.Setters>
                                                    <Setter Property="BackgroundColor" Value="#3D3D4D" />
                                                    <Setter Property="Scale" Value="1.04" />
                                                </VisualState.Setters>
                                            </VisualState>
                                        </VisualStateGroup>
                                    </VisualStateGroupList>
                                </VisualStateManager.VisualStateGroups>
                            </Button>
                        </HorizontalStackLayout>
                    </Grid>
                </Grid>

                <!-- 2. STATS BANNER -->
                <Grid BackgroundColor="#FF7D29" Padding="20,24" HorizontalOptions="Fill">
                    <Grid.Shadow>
                        <Shadow Brush="Black" Offset="0,4" Radius="10" Opacity="0.3" />
                    </Grid.Shadow>
                    <Grid ColumnDefinitions="*,*,*" MaximumWidthRequest="900" HorizontalOptions="Center" WidthRequest="900">
                        <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center" Spacing="4">
                            <Label Text="5 ZONES" TextColor="White" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="Minières TCA Actives" TextColor="#F2F2F7" FontSize="12" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center" Spacing="4">
                            <Label Text="100+ CAMIONS" TextColor="White" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="En service régulier" TextColor="#F2F2F7" FontSize="12" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center" Spacing="4">
                            <Label Text="98.5%" TextColor="White" FontSize="26" FontAttributes="Bold" HorizontalOptions="Center" />
                            <Label Text="Disponibilité flotte" TextColor="#F2F2F7" FontSize="12" HorizontalOptions="Center" />
                        </VerticalStackLayout>
                    </Grid>
                </Grid>

                <!-- 3. FUNCTIONAL MODULES (Catégories) -->
                <VerticalStackLayout Padding="40,60,40,40" Spacing="30" BackgroundColor="#121216">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="Portail de Gestion Logistique" TextColor="White" FontSize="28" FontAttributes="Bold" HorizontalOptions="Center" />
                        <Label Text="Une plateforme moderne pour centraliser vos données d'extraction de bauxite" TextColor="#8E8E9F" FontSize="15" HorizontalOptions="Center" />
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" ColumnSpacing="20" RowSpacing="20" MaximumWidthRequest="1000" HorizontalOptions="Center">
                        <!-- Camions -->
                        <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#1A1A22" Stroke="#2D2D37" StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.15" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12">
                                <Border Stroke="Transparent" BackgroundColor="#2D231E" WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 10" HorizontalOptions="Start">
                                    <Label Text="🚚" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="Suivi des Camions" TextColor="White" FontAttributes="Bold" FontSize="16" />
                                <Label Text="Gérez la flotte de camions TCA, affectation des chauffeurs et suivi du kilométrage." TextColor="#8E8E9F" FontSize="13" LineHeight="1.2" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Chargements -->
                        <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#1A1A22" Stroke="#2D2D37" StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.15" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12">
                                <Border Stroke="Transparent" BackgroundColor="#1E2824" WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 10" HorizontalOptions="Start">
                                    <Label Text="📥" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="Flux des Chargements" TextColor="White" FontAttributes="Bold" FontSize="16" />
                                <Label Text="Enregistrement des départs, heures de retour et contrôle du nombre de tours journaliers." TextColor="#8E8E9F" FontSize="13" LineHeight="1.2" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Chauffeurs -->
                        <Border Grid.Row="0" Grid.Column="2" BackgroundColor="#1A1A22" Stroke="#2D2D37" StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.15" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12">
                                <Border Stroke="Transparent" BackgroundColor="#1E222D" WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 10" HorizontalOptions="Start">
                                    <Label Text="👤" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="Gestion des Chauffeurs" TextColor="White" FontAttributes="Bold" FontSize="16" />
                                <Label Text="Fiches d'informations, contrats de travail et quotas stricts de chauffeurs autorisés (max 100)." TextColor="#8E8E9F" FontSize="13" LineHeight="1.2" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Groupes -->
                        <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#1A1A22" Stroke="#2D2D37" StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.15" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12">
                                <Border Stroke="Transparent" BackgroundColor="#2A1E2D" WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 10" HorizontalOptions="Start">
                                    <Label Text="🏢" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="Groupes de Transport" TextColor="White" FontAttributes="Bold" FontSize="16" />
                                <Label Text="Regroupement des camions par zone (max 10 groupes au total, 2 groupes max par zone)." TextColor="#8E8E9F" FontSize="13" LineHeight="1.2" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Primes -->
                        <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#1A1A22" Stroke="#2D2D37" StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.15" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12">
                                <Border Stroke="Transparent" BackgroundColor="#2D2C1E" WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 10" HorizontalOptions="Start">
                                    <Label Text="💰" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="Calculateur de Primes" TextColor="White" FontAttributes="Bold" FontSize="16" />
                                <Label Text="Calcul automatique du carburant et primes chauffeurs, superviseurs et administrateurs." TextColor="#8E8E9F" FontSize="13" LineHeight="1.2" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Statistiques -->
                        <Border Grid.Row="1" Grid.Column="2" BackgroundColor="#1A1A22" Stroke="#2D2D37" StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.15" />
                            </Border.Shadow>
                            <VerticalStackLayout Spacing="12">
                                <Border Stroke="Transparent" BackgroundColor="#1E2B2D" WidthRequest="50" HeightRequest="50" StrokeShape="RoundRectangle 10" HorizontalOptions="Start">
                                    <Label Text="📊" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <Label Text="Statistiques Shift" TextColor="White" FontAttributes="Bold" FontSize="16" />
                                <Label Text="Analyses détaillées de la production de bauxite, du carburant consommé et des coûts mensuels." TextColor="#8E8E9F" FontSize="13" LineHeight="1.2" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <!-- 4. COMMENT ÇA MARCHE (Workflow) -->
                <Grid ColumnDefinitions="*,*" Padding="40,80,40,80" BackgroundColor="#0F0F12" MaximumWidthRequest="1000" HorizontalOptions="Center">
                    <!-- Illustration de gauche (Glassmorphism card) -->
                    <Border Grid.Column="0" BackgroundColor="#16161C" Stroke="#23232C" StrokeThickness="1.5" StrokeShape="RoundRectangle 16" Padding="30" VerticalOptions="Center" Margin="0,0,40,0">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.25" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="20">
                            <Label Text="Intégrité Référentielle" TextColor="#FF7D29" FontSize="14" FontAttributes="Bold" CharacterSpacing="1" />
                            <Label Text="Règles Métier Intégrées" TextColor="White" FontSize="24" FontAttributes="Bold" />
                            <Label Text="Notre système applique en temps réel les contraintes imposées par la base de données et les règles d'exploitation minières (ON DELETE RESTRICT, limites de tours, heures limites)." TextColor="#8E8E9F" FontSize="14" LineHeight="1.3" />
                            <Border Stroke="Transparent" BackgroundColor="#23232C" StrokeShape="RoundRectangle 6" Padding="12" HorizontalOptions="Start">
                                <Label Text="🛡️ Données Sécurisées" TextColor="White" FontSize="13" FontAttributes="Bold" />
                            </Border>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Etapes de droite -->
                    <VerticalStackLayout Grid.Column="1" Spacing="30" VerticalOptions="Center">
                        <Label Text="Le cycle logistique d'un chargement" TextColor="White" FontSize="28" FontAttributes="Bold" />

                        <!-- Etape 1 -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="20">
                            <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22" BackgroundColor="#2D231E" Stroke="#FF7D29" StrokeThickness="1.5">
                                <Label Text="1" TextColor="#FF7D29" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Planification &amp; Départ" TextColor="White" FontAttributes="Bold" FontSize="16" />
                                <Label Text="Déclarer le départ d'un camion vers une zone de chargement active (limite stricte avant 17h30)." TextColor="#8E8E9F" FontSize="13" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Etape 2 -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="20">
                            <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22" BackgroundColor="#1E2824" Stroke="#4CD964" StrokeThickness="1.5">
                                <Label Text="2" TextColor="#4CD964" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Déchargement &amp; Clôture" TextColor="White" FontAttributes="Bold" FontSize="16" />
                                <Label Text="Au retour du camion au dépôt principal, enregistrement de la clôture du chargement." TextColor="#8E8E9F" FontSize="13" />
                            </VerticalStackLayout>
                        </Grid>

                        <!-- Etape 3 -->
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="20">
                            <Border Grid.Column="0" WidthRequest="44" HeightRequest="44" StrokeShape="RoundRectangle 22" BackgroundColor="#1E222D" Stroke="#007AFF" StrokeThickness="1.5">
                                <Label Text="3" TextColor="#007AFF" FontAttributes="Bold" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>
                            <VerticalStackLayout Grid.Column="1" Spacing="4">
                                <Label Text="Traitement Financier" TextColor="White" FontAttributes="Bold" FontSize="16" />
                                <Label Text="Le système calcule le carburant aller-retour (2L/km) et injecte les primes correspondantes." TextColor="#8E8E9F" FontSize="13" />
                            </VerticalStackLayout>
                        </Grid>
                    </VerticalStackLayout>
                </Grid>

                <!-- 5. ACTIVE MINING ZONES -->
                <VerticalStackLayout Padding="40,60" Spacing="30" BackgroundColor="#121216">
                    <Grid ColumnDefinitions="*,Auto" MaximumWidthRequest="1000" HorizontalOptions="Center" WidthRequest="1000" Margin="0,0,0,10">
                        <VerticalStackLayout Grid.Column="0" Spacing="6">
                            <Label Text="Zones Minières Actives" TextColor="White" FontSize="28" FontAttributes="Bold" />
                            <Label Text="Configuration des tarifs et des quotas de transport officiels par site." TextColor="#8E8E9F" FontSize="14" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Voir toutes les zones" BackgroundColor="Transparent" TextColor="#FF7D29" FontAttributes="Bold" BorderColor="#FF7D29" BorderWidth="1" HeightRequest="40" CornerRadius="6" Padding="16,0" Clicked="OnSeConnecterClicked" />
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="20" MaximumWidthRequest="1000" HorizontalOptions="Center">
                        <!-- Bankoh -->
                        <Border Grid.Column="0" BackgroundColor="#1A1A22" Stroke="#2D2D37" StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.15" />
                            </Border.Shadow>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                                <HorizontalStackLayout Grid.Row="0" Spacing="8">
                                    <Border Stroke="Transparent" BackgroundColor="#2D231E" Padding="6,2" StrokeShape="RoundRectangle 4">
                                        <Label Text="Zone 1" TextColor="#FF7D29" FontSize="10" FontAttributes="Bold" />
                                    </Border>
                                    <Label Text="ACTIVE" TextColor="#4CD964" FontSize="10" FontAttributes="Bold" VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <Label Grid.Row="1" Text="Bankoh" TextColor="White" FontSize="22" FontAttributes="Bold" />

                                <HorizontalStackLayout Grid.Row="2" Spacing="6">
                                    <Label Text="📍" FontSize="14" />
                                    <Label Text="25 km (Aller-Retour : 50 km)" TextColor="#8E8E9F" FontSize="13" VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Row="3" Spacing="6">
                                    <Label Text="🔄" FontSize="14" />
                                    <Label Text="Max 4 tours / jour" TextColor="#8E8E9F" FontSize="13" VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <Border Grid.Row="4" BackgroundColor="#23232C" Stroke="Transparent" Padding="12" StrokeShape="RoundRectangle 6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="Tarif :" TextColor="#8E8E9F" FontSize="13" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="4 500 000 GNF" TextColor="#FF7D29" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Djoumaya -->
                        <Border Grid.Column="1" BackgroundColor="#1A1A22" Stroke="#2D2D37" StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.15" />
                            </Border.Shadow>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                                <HorizontalStackLayout Grid.Row="0" Spacing="8">
                                    <Border Stroke="Transparent" BackgroundColor="#2D231E" Padding="6,2" StrokeShape="RoundRectangle 4">
                                        <Label Text="Zone 2" TextColor="#FF7D29" FontSize="10" FontAttributes="Bold" />
                                    </Border>
                                    <Label Text="ACTIVE" TextColor="#4CD964" FontSize="10" FontAttributes="Bold" VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <Label Grid.Row="1" Text="Djoumaya" TextColor="White" FontSize="22" FontAttributes="Bold" />

                                <HorizontalStackLayout Grid.Row="2" Spacing="6">
                                    <Label Text="📍" FontSize="14" />
                                    <Label Text="37 km (Aller-Retour : 74 km)" TextColor="#8E8E9F" FontSize="13" VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <HorizontalStackLayout Grid.Row="3" Spacing="6">
                                    <Label Text="🔄" FontSize="14" />
                                    <Label Text="Max 3 tours / jour" TextColor="#8E8E9F" FontSize="13" VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <Border Grid.Row="4" BackgroundColor="#23232C" Stroke="Transparent" Padding="12" StrokeShape="RoundRectangle 6">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <Label Grid.Column="0" Text="Tarif :" TextColor="#8E8E9F" FontSize="13" VerticalOptions="Center" />
                                        <Label Grid.Column="1" Text="5 700 000 GNF" TextColor="#FF7D29" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>

                        <!-- Timbi -->
                        <Border Grid.Column="2" BackgroundColor="#1A1A22" Stroke="#2D2D37" StrokeThickness="1.5" StrokeShape="RoundRectangle 12" Padding="20">
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.15" />
                            </Border.Shadow>
                            <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="12">
                                <HorizontalStackLayout Grid.Row="0" Spacing="8">
