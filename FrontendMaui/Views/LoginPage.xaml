<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="FrontendMaui.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:FrontendMaui.ViewModels"
    x:DataType="viewmodels.LoginViewModel"
    Shell.NavBarIsVisible="False">

    <Grid>
        <!-- Dégradé de fond sombre et premium -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#1E1E24" Offset="0.0" />
                <GradientStop Color="#121214" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <ScrollView VerticalOptions="Center">
            <VerticalStackLayout Spacing="28" Padding="30" MaximumWidthRequest="450" HorizontalOptions="Fill">

                <!-- Logo & Titre -->
                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                    <Label
                        Text="TCA"
                        FontSize="42"
                        FontAttributes="Bold"
                        TextColor="#FF6B1A"
                        HorizontalOptions="Center" />
                    <Label
                        Text="Connexion au portail logistique"
                        FontSize="16"
                        TextColor="#A0A0A0"
                        HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Formulaire -->
                <VerticalStackLayout Spacing="16">
                    <!-- Identifiant -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Identifiant" TextColor="#D0D0D0" FontSize="14" />
                        <Border Stroke="#3D3D45" StrokeThickness="1.5" StrokeShape="RoundRectangle 8" BackgroundColor="#25252B" Padding="8,2">
                            <Entry
                                Text="{Binding Identifiant}"
                                Placeholder="Entrez votre identifiant"
                                PlaceholderColor="#707075"
                                TextColor="White"
                                HeightRequest="44" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Mot de passe -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Mot de passe" TextColor="#D0D0D0" FontSize="14" />
                        <Border Stroke="#3D3D45" StrokeThickness="1.5" StrokeShape="RoundRectangle 8" BackgroundColor="#25252B" Padding="8,2">
                            <Entry
                                Text="{Binding MotDePasse}"
                                IsPassword="True"
                                Placeholder="Entrez votre mot de passe"
                                PlaceholderColor="#707075"
                                TextColor="White"
                                HeightRequest="44" />
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <!-- Affichage d'erreur -->
                <Label
                    Text="{Binding ErrorMessage}"
                    TextColor="#FF4B4B"
                    FontSize="14"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    IsVisible="{Binding HasError}" />

                <!-- Bouton Connexion / Indicateur de chargement -->
                <Grid HeightRequest="50">
                    <Button
                        Text="Se connecter"
                        Command="{Binding LoginCommand}"
                        BackgroundColor="#FF6B1A"
                        TextColor="White"
                        FontAttributes="Bold"
                        CornerRadius="8"
                        IsVisible="{Binding IsNotBusy}" />
                    
                    <ActivityIndicator
                        IsRunning="{Binding IsBusy}"
                        IsVisible="{Binding IsBusy}"
                        Color="#FF6B1A"
                        HeightRequest="40"
                        HorizontalOptions="Center"
                        VerticalOptions="Center" />
                </Grid>

                <!-- Lien retour -->
                <Label
                    Text="Retour à l'accueil"
                    TextColor="#A0A0A0"
                    TextDecorations="Underline"
                    HorizontalOptions="Center"
                    FontSize="14"
                    Margin="0,10,0,0">
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnRetourTapped" />
                    </Label.GestureRecognizers>
                </Label>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>

</ContentPage>
