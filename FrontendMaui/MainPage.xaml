<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FrontendMaui.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a submarine number ten" />

            <Label
                Text="TCA Logistique Minière"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Système de gestion des transports et chargements"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2" />

            <Frame Margin="0,20" Padding="20" CornerRadius="15" BackgroundColor="{StaticResource Secondary}">
                <Label Text="Bienvenue dans l'application de supervision logistique. Utilisez les onglets ci-dessous pour gérer les chauffeurs, les groupes de transport, les zones minières et consulter les statistiques."
                       HorizontalTextAlignment="Center" />
            </Frame>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
